#!/bin/bash
parser="$HOME/.config/theme-setter/scripts/parser.sh"

if [ "$1" == "--theme" ]; then
    $parser --theme
elif [ "$1" == "--mode" ]; then
    $parser --mode
elif [ "$1" == "--tone" ]; then
    $parser --tone
elif [ "$1" == "--palette" ]; then
    $parser --palette $2
elif [ "$1" == "--full-palette" ]; then
    $parser --full-palette
fi
